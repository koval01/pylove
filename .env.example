# Copy to .env: cp .env.example .env

# For the native MQTT bridge (``python -m lovensepy.services.mqtt_bridge`` / ``lovensepy-mqtt``): LAN Game Mode host IP when LOVENSE_TRANSPORT=lan.
# Not used by docker compose (only Mosquitto + Home Assistant).
LOVENSE_LAN_IP=192.168.1.100

# Native bridge: lan or ble (Compose does not run the bridge).
LOVENSE_TRANSPORT=lan

# Published ports on the host
HOME_ASSISTANT_PORT=8123
MQTT_PUBLISH_PORT=1883

# Time zone for Home Assistant
TZ=UTC
